# --- Inference backend ---
# mock  = Pillow placeholder images, runs anywhere (default; CI / non-Mac dev)
# mflux = real MLX/Metal FLUX backend (Apple Silicon only)
INFERENCE_BACKEND=mock
MODEL_ID=black-forest-labs/FLUX.2-klein-9B
QUANTIZATION=4
DEVICE=mps

# --- Hugging Face (only needed for the mflux/diffusers paths) ---
# HF_TOKEN=hf_xxx
# Accept the gated license at the model page before downloading.

# --- API ---
API_BIND_HOST=127.0.0.1
API_BIND_PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# --- Generation defaults ---
DEFAULT_STEPS=4
DEFAULT_GUIDANCE=3.5
DEFAULT_WIDTH=512
DEFAULT_HEIGHT=512

# --- Queue ---
QUEUE_BACKEND=asyncio   # asyncio (local) | valkey (multi-user)
GPU_CONCURRENCY=1

# --- Storage (defaults to ~/Library/Application Support/flux-local on macOS,
#     ./data elsewhere) ---
# DATA_DIR=/path/to/data
MAX_UPLOAD_BYTES=26214400
MAX_UPLOAD_DIMENSION=4096
